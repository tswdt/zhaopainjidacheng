.home-page {
  background: #FFFFFF;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* Hero区域 */
.hero {
  padding: 24rpx 40rpx 32rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: -0.5px;
}

.hero-title-dark {
  color: #1A1A1A;
}

.hero-title-gold {
  color: #B87300;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #8A94A6;
  margin-top: 12rpx;
  font-weight: 400;
}

/* Action按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx;
  margin-bottom: 48rpx;
}

.action-btn {
  flex: 1;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border-radius: 24rpx;
  padding: 32rpx 0;
  min-height: 180rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.action-btn.primary {
  background: #1A1A1A;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 26, 0.15);
}

.action-btn.secondary {
  background: #F5F5F5;
  color: #1A1A1A;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon-wrap.primary-icon {
  background: rgba(255, 255, 255, 0.15);
}

.action-icon-wrap.secondary-icon {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.action-label {
  font-size: 26rpx;
  font-weight: 500;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.hot-section-header {
  margin-top: 48rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #8A94A6;
  transition: opacity var(--duration-fast) var(--ease-out);
}

.section-more:active {
  opacity: 0.7;
}

/* AI能力网格 */
.capability-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 40rpx;
  column-gap: 20rpx;
  row-gap: 20rpx;
}

.capability-card {
  width: calc((100% - 20rpx) / 2);
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F0F0F0;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.capability-card:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.capability-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.capability-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.capability-desc {
  font-size: 22rpx;
  color: #8A94A6;
  line-height: 1.4;
}

/* 热门场景横向滚动 */
.hot-scroll {
  width: 100%;
}

.hot-list {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx;
}

.hot-card {
  flex-shrink: 0;
  width: 200rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #F0F0F0;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.hot-card:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.hot-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.hot-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #1A1A1A;
  text-align: center;
  line-height: 1.3;
}

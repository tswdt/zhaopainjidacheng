page {
  --color-primary: #171717;
  --color-primary-hover: #404040;
  --color-primary-active: #0a0a0a;
  --color-accent: #A16207;
  --color-accent-light: #fef3c7;
  --color-accent-bg: #fefdf8;
  --color-bg-page: #f8f8f8;
  --color-bg-card: #ffffff;
  --color-bg-input: #f5f5f5;
  --color-text-primary: #171717;
  --color-text-secondary: #666666;
  --color-text-placeholder: #999999;
  --color-text-disabled: #cccccc;
  --color-border: #e5e5e5;
  --color-border-light: #f0f0f0;
  --color-divider: #f5f5f5;
  --color-icon-bg-blue: #dbeafe;
  --color-icon-bg-green: #dcfce7;
  --color-icon-bg-pink: #fce7f3;
  --color-icon-bg-indigo: #e0e7ff;
  --color-icon-bg-purple: #f3e8ff;
  --color-icon-bg-amber: #fef3c7;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-elevated: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --font-size-xs: 20rpx;
  --font-size-sm: 22rpx;
  --font-size-base: 28rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-3xl: 64rpx;
  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
}

.scan-header {
  padding: 48rpx var(--spacing-page) var(--spacing-md);
  background: var(--bg-card);
}

.scan-title {
  font-size: var(--font-size-xl);
  font-weight: 800;
  color: var(--text-primary);
}

.scan-subtitle {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.scan-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--spacing-md) var(--spacing-page) 0;
  column-gap: var(--spacing-card-gap);
  row-gap: var(--spacing-card-gap);
}

.scan-card {
  width: 323rpx;
  box-sizing: border-box;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg) var(--spacing-md);
  box-shadow: var(--shadow-card);
  min-height: 180rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.scan-card:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.scan-card-icon {
  margin-bottom: 16rpx;
}

.scan-card-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.scan-card-desc {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 var(--spacing-page);
  column-gap: var(--spacing-card-gap);
  row-gap: var(--spacing-card-gap);
}

.quick-card {
  width: 323rpx;
  box-sizing: border-box;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md) var(--spacing-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-card);
  min-height: 140rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.quick-card:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

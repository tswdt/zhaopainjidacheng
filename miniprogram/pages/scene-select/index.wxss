.search-bar {
  padding: var(--spacing-sm) var(--spacing-page);
  background: var(--bg-card);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 28rpx;
  padding: var(--spacing-sm) var(--spacing-md);
  min-height: 80rpx;
  border: 2rpx solid transparent;
  transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
}

.search-input-wrap.input-focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(184, 115, 0, 0.12);
  background: #FFFFFF;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  margin-left: 12rpx;
}

.search-placeholder {
  color: var(--text-tertiary);
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #C4C9D4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  flex-shrink: 0;
  transition: background var(--duration-fast) var(--ease-out);
}

.search-clear:active {
  background: #9CA3AF;
}

.category-list {
  padding: var(--spacing-sm) 0;
}

.category {
  margin-bottom: var(--spacing-sm);
}

.category-title {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--text-primary);
  padding: var(--spacing-sm) var(--spacing-page) 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.scene-list {
  padding: 0 var(--spacing-sm);
}

.scene-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
  min-height: 100rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.scene-item:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.scene-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.scene-item-info {
  flex: 1;
  min-width: 0;
}

.scene-item-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
}

.scene-item-desc {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scene-item-cost {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

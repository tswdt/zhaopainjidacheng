.result-preview {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.result-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f0fff4;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
}

.result-badge-text {
  font-size: var(--font-size-xs);
  color: #52c41a;
  font-weight: var(--font-weight-medium);
}

.compare-area {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

.compare-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.compare-img {
  width: 100%;
  height: 280rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-input);
}

.compare-placeholder {
  width: 100%;
  height: 280rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-input);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
}

.placeholder-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

.compare-arrow {
  flex-shrink: 0;
}

.result-actions {
  display: flex;
  gap: var(--spacing-md);
}

.action-retry {
  flex: 1;
  --td-button-light-bg-color: var(--color-bg-card);
  --td-button-light-border-color: var(--color-border);
  border-radius: var(--radius-full) !important;
}

.action-save {
  flex: 1;
  --td-button-primary-bg-color: var(--color-primary);
  --td-button-primary-border-color: var(--color-primary);
  border-radius: var(--radius-full) !important;
}

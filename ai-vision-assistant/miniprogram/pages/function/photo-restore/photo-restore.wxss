.page-function {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-page);
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) var(--spacing-xl);
  background: var(--color-bg-card);
  gap: 0;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-bg-input);
  color: var(--color-text-placeholder);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-active .step-num {
  background: var(--color-primary);
  color: #ffffff;
}

.step-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

.step-active .step-label {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: var(--color-bg-input);
  margin: 0 8rpx;
  margin-bottom: 32rpx;
}

.step-line-active {
  background: var(--color-primary);
}

.content {
  flex: 1;
  overflow: hidden;
}

.step-content {
  padding: var(--spacing-lg);
}

.preview-image {
  margin-bottom: var(--spacing-lg);
}

.uploaded-img {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-lg);
}

.options-section {
  margin-bottom: var(--spacing-lg);
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.option-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  margin-left: 48rpx;
}

.option-price {
  font-size: var(--font-size-sm);
  color: var(--color-accent);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}

.submit-area {
  padding: var(--spacing-md) 0;
}

.submit-btn {
  --td-button-primary-bg-color: var(--color-primary);
  --td-button-primary-border-color: var(--color-primary);
  border-radius: var(--radius-full) !important;
}

.processing-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding-top: 200rpx;
}

.processing-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.processing-text {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.processing-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

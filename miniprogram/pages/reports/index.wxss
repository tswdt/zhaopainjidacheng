.reports-header {
  padding: var(--spacing-md) var(--spacing-page) var(--spacing-sm);
  background: var(--bg-card);
}

.reports-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.reports-count {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.filter-tabs {
  display: flex;
  padding: var(--spacing-sm) var(--spacing-page);
  gap: var(--spacing-sm);
  background: var(--bg-card);
  margin-bottom: 8rpx;
}

.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-size: var(--font-size-sm);
  background: #F8F9FA;
  color: var(--text-secondary);
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--duration-normal) var(--ease-out), color var(--duration-normal) var(--ease-out), box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-fast) var(--ease-out);
}

.filter-tab:active {
  transform: scale(0.95);
}

.filter-tab.active {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(184, 115, 0, 0.25);
}

.report-list {
  padding: 0 var(--spacing-page);
}

.report-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.report-card:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.report-card-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.report-card-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.report-card-info {
  flex: 1;
  min-width: 0;
}

.report-card-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-card-scene {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 2rpx;
}

.report-card-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
  flex-shrink: 0;
}

.report-card-status.done {
  background: var(--color-success-light);
  color: var(--color-success);
}

.report-card-status.processing {
  background: var(--color-caution-light);
  color: var(--color-caution);
}

.report-card-status.failed {
  background: var(--color-warn-light);
  color: var(--color-warn);
}

.report-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.report-card-time {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

.report-card-cost {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 24rpx;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

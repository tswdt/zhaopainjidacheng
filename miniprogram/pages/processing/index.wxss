.processing-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 0 var(--spacing-page);
}

.processing-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

.processing-done-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-success-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  animation: fadeIn var(--duration-normal) var(--ease-out) both;
}

.processing-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.processing-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
}

.progress-bar-wrap {
  width: 100%;
  max-width: 500rpx;
  height: 8rpx;
  background: var(--border-color);
  border-radius: 4rpx;
  overflow: hidden;
  margin-top: 24rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #D4A017);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: 500rpx;
  margin-top: 32rpx;
  padding: 0 16rpx;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--border-color);
  transition: background var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
}

.progress-step.done .step-dot {
  background: var(--color-primary);
}

.progress-step.active .step-dot {
  background: var(--color-primary);
  transform: scale(1.3);
  box-shadow: 0 0 0 6rpx rgba(184, 115, 0, 0.2);
}

.step-label {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
  transition: color var(--duration-normal) var(--ease-out);
}

.progress-step.done .step-label {
  color: var(--color-primary);
}

.progress-step.active .step-label {
  color: var(--text-primary);
  font-weight: 600;
}

.processing-tip {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
  margin-top: 24rpx;
  text-align: center;
}

.processing-cancel {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  border-radius: 28rpx;
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  background: #F8F9FA;
  transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
}

.processing-cancel:active {
  background: #E8EBF0;
  color: var(--text-primary);
}

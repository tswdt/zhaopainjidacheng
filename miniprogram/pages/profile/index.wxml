<view class="page">
  <view class="profile-header">
    <view class="avatar-wrap">
      <view class="avatar">👤</view>
    </view>
    <view class="user-name">用户</view>
  </view>

  <view class="credits-card">
    <view class="credits-row">
      <view class="credits-info">
        <view class="credits-label">积分余额</view>
        <view class="credits-value">{{credits}}</view>
      </view>
      <view class="credits-btn" bindtap="rechargeCredits">充值积分</view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-value">{{statReports}}</view>
      <view class="stat-label">已完成报告</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{statProcessing}}</view>
      <view class="stat-label">处理中</view>
    </view>
  </view>

  <view class="upgrade-card">
    <view class="upgrade-top">
      <view class="upgrade-title">⭐ 升级会员</view>
      <view class="upgrade-desc">解锁更多场景和优惠积分</view>
    </view>
    <view class="upgrade-btn" bindtap="subscribeMember">立即开通</view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goCreditsDetail">
      <view class="menu-icon-wrap"><view class="menu-icon-text">💰</view></view>
      <view class="menu-text">积分明细</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="subscribeMember">
      <view class="menu-icon-wrap"><view class="menu-icon-text">⭐</view></view>
      <view class="menu-text">会员订阅</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goOrders">
      <view class="menu-icon-wrap"><view class="menu-icon-text">📋</view></view>
      <view class="menu-text">订单记录</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <view class="menu-icon-wrap"><view class="menu-icon-text">⚙️</view></view>
      <view class="menu-text">设置</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-icon-wrap"><view class="menu-icon-text">ℹ️</view></view>
      <view class="menu-text">关于平台</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>
</view>

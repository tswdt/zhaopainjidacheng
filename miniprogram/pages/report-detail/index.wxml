<view class="page">
  <view class="report-header">
    <view class="report-header-icon" style="background:{{report.iconBg}}">{{report.icon}}</view>
    <view class="report-header-title">{{report.title}}</view>
    <view class="report-header-summary">{{report.summary}}</view>
    <view class="report-meta">
      <text class="meta-item">{{report.sceneName}}</text>
      <text class="meta-dot">·</text>
      <text class="meta-item">{{report.costCredits}}积分</text>
    </view>
  </view>

  <view class="ai-summary" wx:if="{{result.summary}}">
    <view class="ai-summary-title">💡 AI摘要</view>
    <view class="ai-summary-text">{{result.summary}}</view>
  </view>

  <block wx:if="{{report.reportType === 'documentRead'}}">
    <view class="detail-section" wx:for="{{result.sections}}" wx:key="sectionId">
      <view class="detail-section-title">📋 {{item.title}}</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{item.data.fields}}" wx:for-item="field" wx:key="key">
          <text class="detail-key">{{field.key}}</text>
          <text class="detail-val {{field.type === 'amount' ? 'gold' : ''}}">{{field.value}}</text>
        </view>
        <view class="detail-row" wx:for="{{item.data.items}}" wx:for-item="li" wx:key="index">
          <text class="detail-val">{{li.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.uncertainFields && result.uncertainFields.length}}">
      <view class="detail-section-title">❓ 不确定字段</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.uncertainFields}}" wx:key="key">
          <text class="detail-key">{{item.key}}</text>
          <text class="detail-val warn">{{item.reason || item.value}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'healthReport'}}">
    <view class="risk-card" wx:if="{{result.abnormalItems && result.abnormalItems.length}}">
      <view class="risk-title">⚠️ 异常指标</view>
      <view class="detail-row" wx:for="{{result.abnormalItems}}" wx:key="name">
        <text class="detail-key">{{item.name}}</text>
        <text class="detail-val warn">{{item.value}} {{item.direction}} (参考: {{item.ref}})</text>
      </view>
    </view>
    <view class="detail-section">
      <view class="detail-section-title">✅ 正常指标</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.normalItems}}" wx:key="name">
          <text class="detail-key">{{item.name}}</text>
          <text class="detail-val green">{{item.value}} (参考: {{item.ref}})</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.explanations && result.explanations.length}}">
      <view class="detail-section-title">📖 指标解释</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.explanations}}" wx:key="name">
          <text class="detail-key">{{item.name}}</text>
          <text class="detail-val">{{item.explain}}</text>
        </view>
      </view>
    </view>
    <view class="suggest-card" wx:if="{{result.focusPoints && result.focusPoints.length}}">
      <view class="suggest-title">🔍 重点关注</view>
      <view class="suggest-list">
        <view class="suggest-list-item" wx:for="{{result.focusPoints}}" wx:key="index">• {{item.text}}</view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.suggestedQuestions && result.suggestedQuestions.length}}">
      <view class="detail-section-title">💬 建议咨询医生</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.suggestedQuestions}}" wx:key="index">
          <text class="detail-val">{{item.text}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'medicineReport'}}">
    <view class="detail-section">
      <view class="detail-section-title">💊 药品信息</view>
      <view class="detail-card">
        <view class="detail-row"><text class="detail-key">药品名称</text><text class="detail-val gold">{{result.medicineName}}</text></view>
        <view class="detail-row"><text class="detail-key">成分</text><text class="detail-val">{{result.ingredients}}</text></view>
        <view class="detail-row"><text class="detail-key">适应症</text><text class="detail-val">{{result.indications}}</text></view>
        <view class="detail-row"><text class="detail-key">用法</text><text class="detail-val">{{result.usage}}</text></view>
        <view class="detail-row"><text class="detail-key">用量</text><text class="detail-val gold">{{result.dosage}}</text></view>
      </view>
    </view>
    <view class="risk-card" wx:if="{{result.contraindications && result.contraindications.length}}">
      <view class="risk-title">🚫 禁忌</view>
      <view class="risk-text" wx:for="{{result.contraindications}}" wx:key="index">• {{item.text}}</view>
    </view>
    <view class="detail-section" wx:if="{{result.sideEffects && result.sideEffects.length}}">
      <view class="detail-section-title">⚡ 不良反应</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.sideEffects}}" wx:key="index">
          <text class="detail-val warn">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.specialGroups && result.specialGroups.length}}">
      <view class="detail-section-title">👥 特殊人群</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.specialGroups}}" wx:key="group">
          <text class="detail-key">{{item.group}}</text>
          <text class="detail-val">{{item.note}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'foodLabelReport'}}">
    <view class="detail-section">
      <view class="detail-section-title">🧪 配料表</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.ingredients}}" wx:key="index">
          <text class="detail-val">{{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.nutrition}}">
      <view class="detail-section-title">📊 营养成分</view>
      <view class="detail-card">
        <view class="detail-row" wx:if="{{result.nutrition.calories}}"><text class="detail-key">热量</text><text class="detail-val">{{result.nutrition.calories}}</text></view>
        <view class="detail-row" wx:if="{{result.nutrition.sugar}}"><text class="detail-key">糖</text><text class="detail-val">{{result.nutrition.sugar}}</text></view>
        <view class="detail-row" wx:if="{{result.nutrition.fat}}"><text class="detail-key">脂肪</text><text class="detail-val">{{result.nutrition.fat}}</text></view>
        <view class="detail-row" wx:if="{{result.nutrition.sodium}}"><text class="detail-key">钠</text><text class="detail-val">{{result.nutrition.sodium}}</text></view>
        <view class="detail-row" wx:if="{{result.nutrition.protein}}"><text class="detail-key">蛋白质</text><text class="detail-val">{{result.nutrition.protein}}</text></view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.sugarFatSodiumAnalysis}}">
      <view class="detail-section-title">⚖️ 糖脂钠评估</view>
      <view class="detail-card">
        <view class="detail-row" wx:if="{{result.sugarFatSodiumAnalysis.sugar}}"><text class="detail-key">糖</text><text class="detail-val {{result.sugarFatSodiumAnalysis.sugar === '高' ? 'warn' : 'green'}}">{{result.sugarFatSodiumAnalysis.sugar}}</text></view>
        <view class="detail-row" wx:if="{{result.sugarFatSodiumAnalysis.fat}}"><text class="detail-key">脂肪</text><text class="detail-val {{result.sugarFatSodiumAnalysis.fat === '高' ? 'warn' : 'green'}}">{{result.sugarFatSodiumAnalysis.fat}}</text></view>
        <view class="detail-row" wx:if="{{result.sugarFatSodiumAnalysis.sodium}}"><text class="detail-key">钠</text><text class="detail-val {{result.sugarFatSodiumAnalysis.sodium === '高' ? 'warn' : 'green'}}">{{result.sugarFatSodiumAnalysis.sodium}}</text></view>
      </view>
    </view>
    <view class="risk-card" wx:if="{{result.allergenWarnings && result.allergenWarnings.length}}">
      <view class="risk-title">⚠️ 过敏原警告</view>
      <view class="risk-text" wx:for="{{result.allergenWarnings}}" wx:key="index">• {{item.text}}</view>
    </view>
    <view class="suggest-card" wx:if="{{result.purchaseAdvice}}">
      <view class="suggest-title">💡 购买建议</view>
      <view class="suggest-list-item">{{result.purchaseAdvice}}</view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'imageRepair'}}">
    <view class="detail-section">
      <view class="detail-section-title">🖼️ 修复前后对比</view>
      <view class="compare-card">
        <view class="compare-item"><text class="compare-label">修复前</text><text class="compare-text">{{result.beforeAfter.before}}</text></view>
        <view class="compare-arrow">→</view>
        <view class="compare-item"><text class="compare-label">修复后</text><text class="compare-text green">{{result.beforeAfter.after}}</text></view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.repairTypes && result.repairTypes.length}}">
      <view class="detail-section-title">🔧 修复详情</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.repairTypes}}" wx:key="type">
          <text class="detail-key">{{item.type}}</text>
          <text class="detail-val">{{item.detail}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.outputResolution}}">
      <view class="detail-section-title">📐 输出分辨率</view>
      <view class="detail-card">
        <view class="detail-row"><text class="detail-key">分辨率</text><text class="detail-val green">{{result.outputResolution}}</text></view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'spaceDesign'}}">
    <view class="detail-section">
      <view class="detail-section-title">🎨 推荐风格</view>
      <view class="detail-card">
        <view class="detail-row"><text class="detail-key">风格</text><text class="detail-val gold">{{result.style}}</text></view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.spaceProblems && result.spaceProblems.length}}">
      <view class="detail-section-title">🔍 空间问题</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.spaceProblems}}" wx:key="index">
          <text class="detail-val">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.colorPlan && result.colorPlan.length}}">
      <view class="detail-section-title">🎨 配色方案</view>
      <view class="color-palette">
        <view class="color-swatch" wx:for="{{result.colorPlan}}" wx:key="index" style="background:{{item}}"></view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.furnitureAdvice && result.furnitureAdvice.length}}">
      <view class="detail-section-title">🛋️ 家具推荐</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.furnitureAdvice}}" wx:key="name">
          <text class="detail-key">{{item.name}}</text>
          <text class="detail-val gold">{{item.price}}</text>
        </view>
      </view>
    </view>
    <view class="budget-card" wx:if="{{result.budgetRange}}">
      <view class="budget-title">💰 预算估算</view>
      <view class="budget-range">{{result.budgetRange}}</view>
      <view class="budget-note" wx:if="{{result.softDecorationAdvice && result.softDecorationAdvice.length}}">含硬装+软装，不含家电</view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'ecommerceReport'}}">
    <view class="detail-section" wx:if="{{result.sellingPoints && result.sellingPoints.length}}">
      <view class="detail-section-title">💎 核心卖点</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.sellingPoints}}" wx:key="index">
          <text class="detail-val gold">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.mainImageAdvice && result.mainImageAdvice.length}}">
      <view class="detail-section-title">📸 主图建议</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.mainImageAdvice}}" wx:key="index">
          <text class="detail-val">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.backgroundAdvice && result.backgroundAdvice.length}}">
      <view class="detail-section-title">🖼️ 背景建议</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.backgroundAdvice}}" wx:key="index">
          <text class="detail-val">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.platformAdvice && result.platformAdvice.length}}">
      <view class="detail-section-title">🏪 平台适配</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.platformAdvice}}" wx:key="platform">
          <text class="detail-key">{{item.platform}}</text>
          <text class="detail-val">{{item.size}} · {{item.note}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'lifeIdentify'}}">
    <view class="detail-section" wx:if="{{result.possibleNames && result.possibleNames.length}}">
      <view class="detail-section-title">🔍 识别结果</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.possibleNames}}" wx:key="name">
          <text class="detail-key">{{item.name}}</text>
          <text class="detail-val {{index === 0 ? 'gold' : ''}}">{{item.confidence}}% {{item.latinName ? '(' + item.latinName + ')' : ''}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.visibleFeatures && result.visibleFeatures.length}}">
      <view class="detail-section-title">👁️ 可见特征</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.visibleFeatures}}" wx:key="index">
          <text class="detail-val">• {{item.text}}</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.similarObjects && result.similarObjects.length}}">
      <view class="detail-section-title">🔄 相似对象</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.similarObjects}}" wx:key="name">
          <text class="detail-key">{{item.name}} ({{item.confidence}}%)</text>
          <text class="detail-val">{{item.diff}}</text>
        </view>
      </view>
    </view>
    <view class="suggest-card" wx:if="{{result.relatedKnowledge}}">
      <view class="suggest-title">📚 相关知识</view>
      <view class="suggest-list-item">{{result.relatedKnowledge}}</view>
    </view>
    <view class="suggest-card" wx:if="{{result.careOrUsageAdvice && result.careOrUsageAdvice.length}}">
      <view class="suggest-title">🌱 养护建议</view>
      <view class="suggest-list">
        <view class="suggest-list-item" wx:for="{{result.careOrUsageAdvice}}" wx:key="index">• {{item.text}}</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{report.reportType === 'generalAnalysis'}}">
    <view class="detail-section">
      <view class="detail-section-title">📝 图片描述</view>
      <view class="detail-card">
        <view class="detail-row"><text class="detail-val">{{result.imageDescription}}</text></view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.possibleScenes && result.possibleScenes.length}}">
      <view class="detail-section-title">🎯 可能场景</view>
      <view class="detail-card">
        <view class="detail-row" wx:for="{{result.possibleScenes}}" wx:key="name">
          <text class="detail-key">{{item.name}}</text>
          <text class="detail-val">{{item.confidence}}%</text>
        </view>
      </view>
    </view>
    <view class="detail-section" wx:if="{{result.candidateCategories && result.candidateCategories.length}}">
      <view class="detail-section-title">🏷️ 候选分类</view>
      <view class="tag-list">
        <view class="tag tag-gold" wx:for="{{result.candidateCategories}}" wx:key="index">{{item.text}}</view>
      </view>
    </view>
    <view class="validation-card" wx:if="{{result.uncertaintyReason}}">
      <view class="validation-title">❓ 不确定原因</view>
      <view class="validation-text">{{result.uncertaintyReason}}</view>
    </view>
    <view class="suggest-card" wx:if="{{result.suggestedNextActions && result.suggestedNextActions.length}}">
      <view class="suggest-title">➡️ 建议下一步</view>
      <view class="suggest-list">
        <view class="suggest-list-item" wx:for="{{result.suggestedNextActions}}" wx:key="index" bindtap="goToScene" data-scene-id="{{item.sceneId}}">• {{item.text}}</view>
      </view>
    </view>
  </block>

  <view class="detail-section" wx:if="{{result.warnings && result.warnings.length}}">
    <view class="detail-section-title">⚠️ 警告</view>
    <view class="detail-card">
      <view class="detail-row" wx:for="{{result.warnings}}" wx:key="index">
        <text class="detail-val {{item.level === 'high' ? 'warn' : ''}}">{{item.level === 'high' ? '🔴' : '🟡'}} {{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{result.actions && result.actions.length}}">
    <view class="detail-section-title">📌 建议操作</view>
    <view class="detail-card">
      <view class="detail-row" wx:for="{{result.actions}}" wx:key="index">
        <text class="detail-val">• {{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="validation-card" wx:if="{{!report.validationValid}}">
    <view class="validation-title">⚠️ 数据校验</view>
    <view class="validation-text">部分数据未通过校验</view>
    <view class="validation-error-item" wx:for="{{report.validationErrors}}" wx:key="field">{{item.field}}: {{item.error}}</view>
  </view>

  <view class="footer">
    <view class="footer-btn-row">
      <view class="footer-btn primary" bindtap="shareReport">📤 分享报告</view>
      <view class="footer-btn outline" bindtap="exportReport">📄 导出</view>
    </view>
    <view class="footer-btn-row">
      <view class="footer-btn gold" bindtap="reProcess">🔄 重新处理</view>
    </view>
  </view>
</view>

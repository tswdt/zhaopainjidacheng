.scan-header {
  padding: 48rpx 32rpx 24rpx;
  background: #FFFFFF;
}

.scan-title {
  font-size: 22px;
  font-weight: 800;
  color: #111827;
}

.scan-subtitle {
  font-size: 12px;
  color: #8A94A6;
  margin-top: 8rpx;
}

.scan-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 32rpx 0;
  column-gap: 20rpx;
  row-gap: 20rpx;
}

.scan-card {
  width: 323rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: opacity 0.15s;
}

.scan-card:active {
  opacity: 0.85;
}

.scan-card-icon {
  font-size: 32px;
  margin-bottom: 14rpx;
}

.scan-card-name {
  font-size: 15px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4rpx;
}

.scan-card-desc {
  font-size: 11px;
  color: #8A94A6;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx;
  column-gap: 20rpx;
  row-gap: 20rpx;
}

.quick-card {
  width: 323rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: opacity 0.15s;
}

.quick-card:active {
  opacity: 0.85;
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 12px;
  font-weight: 600;
  color: #111827;
  text-align: center;
}
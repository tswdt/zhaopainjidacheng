.report-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx var(--spacing-page) 24rpx;
  background: var(--bg-card);
}

.report-header-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  margin-bottom: 16rpx;
}

.report-header-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 8rpx;
}

.report-header-summary {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 12rpx;
}

.report-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

.meta-dot {
  color: var(--text-tertiary);
}

.compare-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.compare-item {
  flex: 1;
}

.compare-label {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
}

.compare-text {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
}

.compare-text.green {
  color: var(--color-success);
}

.compare-arrow {
  font-size: 20px;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.color-palette {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 0;
}

.color-swatch {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-section {
  padding: 0 var(--spacing-page);
  margin-top: 16rpx;
}

.detail-section-title {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.detail-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-key {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-val {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.detail-val.warn { color: var(--color-warn); }
.detail-val.green { color: var(--color-success); }
.detail-val.gold { color: var(--color-primary); font-weight: 600; }

.detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx var(--spacing-page);
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.detail-action-btn {
  flex: 1;
  padding: 22rpx;
  border-radius: var(--radius-btn);
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
}

.detail-action-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

.detail-action-btn.primary:active {
  opacity: 0.85;
}

.detail-action-btn.secondary {
  background: #F8F9FA;
  color: var(--text-primary);
}

.scene-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx var(--spacing-page) var(--spacing-md);
  background: var(--bg-card);
}

.scene-hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.scene-hero-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.scene-hero-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  text-align: center;
}

.upload-area {
  margin: var(--spacing-md) var(--spacing-page);
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-card);
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  min-height: 240rpx;
  transition: border-color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
}

.upload-area:active {
  border-color: var(--color-primary);
  background: rgba(184, 115, 0, 0.03);
}

.upload-area.has-file {
  border-color: var(--color-success);
  border-style: solid;
  background: rgba(5, 150, 105, 0.02);
}

.upload-area.uploading {
  border-color: var(--color-primary);
  border-style: solid;
  background: rgba(184, 115, 0, 0.03);
}

.upload-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.upload-area-text.processing {
  color: var(--color-primary);
}

.upload-area-text {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.upload-area-text.done {
  color: var(--color-success);
}

.upload-area-hint {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

.routing-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.routing-text {
  font-size: var(--font-size-base);
  color: var(--color-primary);
}

.upload-btns {
  display: flex;
  gap: var(--spacing-sm);
  padding: 0 var(--spacing-page);
  margin-bottom: var(--spacing-md);
}

.upload-btn {
  flex: 1;
  padding: 22rpx;
  border-radius: var(--radius-btn);
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 88rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.upload-btn:active {
  transform: scale(0.97);
}

.upload-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

.upload-btn.primary:active {
  opacity: 0.85;
}

.upload-btn.secondary {
  background: #F8F9FA;
  color: var(--text-primary);
}

.upload-btn.outline {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

.features-list {
  padding: 0 var(--spacing-page);
  margin-bottom: var(--spacing-md);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}

.cost-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-page);
  border-top: 1rpx solid var(--border-color);
  margin: 0 var(--spacing-page);
}

.cost-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.cost-value {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-primary);
}

.submit-btn {
  margin: var(--spacing-md) var(--spacing-page);
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.submit-cost {
  font-size: var(--font-size-sm);
  opacity: 0.8;
}

.submit-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  margin-right: 12rpx;
}

.confirm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--duration-normal) var(--ease-out), visibility var(--duration-normal) var(--ease-out);
}

.confirm-overlay.show {
  opacity: 1;
  visibility: visible;
}

.confirm-dialog {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: var(--spacing-lg);
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

.confirm-dialog.show {
  transform: translateY(0);
}

.confirm-header {
  text-align: center;
  margin-bottom: var(--spacing-md);
}

.confirm-icon-wrap {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.confirm-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.confirm-desc {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.confirm-body {
  margin-bottom: 20rpx;
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.confirm-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.confirm-value {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  text-align: right;
  flex: 1;
}

.confirm-value.green { color: var(--color-success); }
.confirm-value.warn { color: var(--color-warn); }

.confirm-mismatch {
  background: var(--color-warn-light);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: var(--font-size-sm);
  color: #991B1B;
  margin-top: 12rpx;
}

.confirm-candidates {
  margin-bottom: 20rpx;
}

.confirm-candidates-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.confirm-candidate-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.candidate-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.candidate-name {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.candidate-conf {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.confirm-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.confirm-btn {
  padding: 22rpx;
  border-radius: var(--radius-btn);
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.confirm-btn:active {
  transform: scale(0.97);
}

.confirm-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

.confirm-btn.primary:active {
  opacity: 0.85;
}

.confirm-btn.secondary {
  background: var(--color-caution-light);
  color: #92400E;
}

.confirm-btn.outline {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

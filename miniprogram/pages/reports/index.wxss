.reports-header {
  padding: 32rpx var(--spacing-page) 16rpx;
  background: var(--bg-card);
}

.reports-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.reports-count {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.filter-tabs {
  display: flex;
  padding: 16rpx var(--spacing-page);
  gap: 16rpx;
  background: var(--bg-card);
  margin-bottom: 8rpx;
}

.filter-tab {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-size: var(--font-size-sm);
  background: #F8F9FA;
  color: var(--text-secondary);
}

.filter-tab.active {
  background: var(--color-primary);
  color: #fff;
}

.report-list {
  padding: 0 var(--spacing-page);
}

.report-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
  transition: opacity 0.15s;
}

.report-card:active {
  opacity: 0.85;
}

.report-card-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.report-card-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.report-card-info {
  flex: 1;
  min-width: 0;
}

.report-card-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-card-scene {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 2rpx;
}

.report-card-status {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
  flex-shrink: 0;
}

.report-card-status.completed {
  background: #ECFDF5;
  color: #059669;
}

.report-card-status.processing {
  background: #FEF3C7;
  color: #D97706;
}

.report-card-status.failed {
  background: #FEF2F2;
  color: #DC2626;
}

.report-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.report-card-time {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
}

.report-card-cost {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

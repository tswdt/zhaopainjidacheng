page {
  --bg-page: #F6F8FB;
  --bg-card: #FFFFFF;
  --text-primary: #111827;
  --text-secondary: #8A94A6;
  --text-tertiary: #B0B8C8;
  --color-primary: #B87300;
  --color-primary-light: #F5E6CC;
  --color-primary-dark: #9A5F00;
  --color-success: #059669;
  --color-success-light: #DCFCE7;
  --color-warn: #DC2626;
  --color-warn-light: #FEE2E2;
  --color-caution: #D97706;
  --color-caution-light: #FEF3C7;
  --color-info: #2563EB;
  --color-info-light: #DBEAFE;
  --border-color: #F1F3F5;
  --border-light: #F8F9FA;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --radius-card: 20rpx;
  --radius-btn: 16rpx;
  --radius-tag: 20rpx;
  --radius-avatar: 50%;
  --spacing-page: 32rpx;
  --spacing-card-gap: 20rpx;
  --spacing-section: 40rpx;
  --font-size-xs: 11px;
  --font-size-sm: 12px;
  --font-size-base: 14px;
  --font-size-md: 15px;
  --font-size-lg: 17px;
  --font-size-xl: 20px;
  --font-size-2xl: 24px;
  --font-size-3xl: 28px;

  background: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  font-size: var(--font-size-base);
  line-height: 1.5;
}

.page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin: var(--spacing-section) var(--spacing-page) 16rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
}

.btn-gold {
  background: linear-gradient(135deg, #C47A00, #B87300);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-size-xs);
  font-weight: 500;
}

.tag-warn {
  background: var(--color-caution-light);
  color: #92400E;
}

.tag-green {
  background: var(--color-success-light);
  color: #166534;
}

.tag-gold {
  background: var(--color-caution-light);
  color: #A16207;
}

.tag-red {
  background: var(--color-warn-light);
  color: #991B1B;
}

.risk-card {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.risk-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: #991B1B;
  margin-bottom: 12rpx;
}

.risk-text {
  font-size: var(--font-size-sm);
  color: #B91C1C;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.suggest-card {
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.suggest-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: #92400E;
  margin-bottom: 12rpx;
}

.suggest-list {
  padding-left: 32rpx;
}

.suggest-list-item {
  font-size: var(--font-size-sm);
  color: #78350F;
  line-height: 1.8;
}

.detail-section {
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.detail-section-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-card);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-key {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-val {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.detail-val.warn {
  color: var(--color-warn);
}

.detail-val.green {
  color: var(--color-success);
}

.detail-val.gold {
  color: var(--color-primary);
  font-weight: 600;
}

.ai-summary {
  background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.ai-summary-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: #92400E;
  margin-bottom: 8rpx;
}

.ai-summary-text {
  font-size: var(--font-size-sm);
  color: #78350F;
  line-height: 1.7;
}

.budget-card {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.budget-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: #1E40AF;
  margin-bottom: 8rpx;
}

.budget-range {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: #1D4ED8;
  margin-bottom: 4rpx;
}

.budget-note {
  font-size: var(--font-size-xs);
  color: #3B82F6;
}

.validation-card {
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.validation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-caution);
  margin-bottom: 8rpx;
}

.validation-text {
  font-size: var(--font-size-sm);
  color: #92400E;
  line-height: 1.6;
}

.validation-error-item {
  font-size: var(--font-size-xs);
  color: #78716C;
  line-height: 1.4;
  margin-top: 4rpx;
}

.footer {
  padding: 24rpx var(--spacing-page);
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  margin-top: 24rpx;
}

.footer-btn-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.footer-btn {
  flex: 1;
  padding: 22rpx;
  border-radius: var(--radius-btn);
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 600;
}

.footer-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

.footer-btn.outline {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.footer-btn.gold {
  background: linear-gradient(135deg, #C47A00, #B87300);
  color: #fff;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cost-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.cost-val {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-primary);
}

.upgrade-card {
  background: linear-gradient(135deg, #1C1917, #292524);
  border-radius: var(--radius-card);
  padding: 32rpx 28rpx;
  margin: var(--spacing-card-gap) var(--spacing-page);
}

.upgrade-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: #F59E0B;
  margin-bottom: 8rpx;
}

.upgrade-desc {
  font-size: var(--font-size-sm);
  color: #D1D5DB;
  margin-bottom: 20rpx;
}

.upgrade-btn {
  background: linear-gradient(135deg, #C47A00, #B87300);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 36rpx;
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 600;
  display: inline-block;
}

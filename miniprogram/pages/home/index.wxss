.hero {
  padding: 48rpx 32rpx 28rpx;
  background: #FFFFFF;
}

.hero-title {
  font-size: 24px;
  font-weight: 800;
  color: #111827;
  letter-spacing: -0.5px;
  line-height: 1.3;
}

.hero-subtitle {
  font-size: 12px;
  color: #8A94A6;
  margin-top: 10rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 28rpx;
  background: #FFFFFF;
}

.action-btn {
  flex: 1;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 20rpx;
  padding: 28rpx 0;
  transition: opacity 0.15s;
}

.action-btn:active {
  opacity: 0.85;
}

.action-btn.primary {
  background: linear-gradient(145deg, #292524, #1C1917);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(28, 25, 23, 0.25);
}

.action-btn.secondary {
  background: #F8F9FA;
  color: #111827;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
}

.action-icon-wrap.primary-icon {
  background: rgba(184, 115, 0, 0.25);
}

.action-icon-text {
  font-size: 28px;
}

.action-label {
  font-size: 12px;
  font-weight: 600;
}

.capability-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx;
  column-gap: 20rpx;
  row-gap: 20rpx;
}

.capability-card {
  width: 323rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: opacity 0.15s;
}

.capability-card:active {
  opacity: 0.85;
}

.capability-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin-bottom: 14rpx;
}

.capability-name {
  font-size: 15px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4rpx;
}

.capability-desc {
  font-size: 11px;
  color: #8A94A6;
}

.hot-list {
  padding: 0 32rpx;
}

.hot-card {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: opacity 0.15s;
}

.hot-card:active {
  opacity: 0.85;
}

.hot-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  min-width: 0;
}

.hot-name {
  font-size: 15px;
  font-weight: 600;
  color: #111827;
}

.hot-cost {
  font-size: 11px;
  color: #B87300;
  margin-top: 4rpx;
}

.hot-arrow {
  font-size: 20px;
  color: #B0B8C8;
  margin-left: 8rpx;
}
<view class="page">
  <view class="hero">
    <view class="hero-title">上传一张图，得到一个结果</view>
    <view class="hero-subtitle">AI帮你识别、分析、修复和生成</view>
  </view>

  <view class="action-row">
    <view class="action-btn primary" bindtap="goScan">
      <view class="action-icon-wrap primary-icon">
        <view class="action-icon-text">📸</view>
      </view>
      <view class="action-label">拍照识别</view>
    </view>
    <view class="action-btn secondary" bindtap="goSceneSelect">
      <view class="action-icon-wrap">
        <view class="action-icon-text">🔍</view>
      </view>
      <view class="action-label">选场景</view>
    </view>
    <view class="action-btn secondary" bindtap="goItemManage">
      <view class="action-icon-wrap">
        <view class="action-icon-text">📦</view>
      </view>
      <view class="action-label">管理物品</view>
    </view>
  </view>

  <view class="section-title">AI能力</view>
  <view class="capability-grid">
    <view class="capability-card" wx:for="{{capabilities}}" wx:key="name" bindtap="goSceneSelect">
      <view class="capability-icon" style="background:{{item.bg}}">{{item.icon}}</view>
      <view class="capability-name">{{item.name}}</view>
      <view class="capability-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="section-title">热门场景</view>
  <view class="hot-list">
    <view class="hot-card" wx:for="{{hotScenes}}" wx:key="sceneId" bindtap="selectScene" data-scene-id="{{item.sceneId}}">
      <view class="hot-icon" style="background:{{item.iconBg}}">{{item.icon}}</view>
      <view class="hot-info">
        <view class="hot-name">{{item.name}}</view>
        <view class="hot-cost">{{item.costCredits === 0 ? '免费' : item.costCredits + '积分'}}</view>
      </view>
      <view class="hot-arrow">›</view>
    </view>
  </view>
</view>

page {
  --bg-page: #F6F8FB;
  --bg-card: #FFFFFF;
  --text-primary: #111827;
  --text-secondary: #5A6478;
  --text-tertiary: #8A94A6;
  --color-primary: #B87300;
  --color-primary-light: #F5E6CC;
  --color-primary-dark: #9A5F00;
  --color-success: #059669;
  --color-success-light: #DCFCE7;
  --color-warn: #DC2626;
  --color-warn-light: #FEE2E2;
  --color-caution: #D97706;
  --color-caution-light: #FEF3C7;
  --color-info: #2563EB;
  --color-info-light: #DBEAFE;
  --border-color: #E8EBF0;
  --border-light: #F1F3F5;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  --radius-card: 20rpx;
  --radius-btn: 16rpx;
  --radius-tag: 20rpx;
  --radius-avatar: 50%;
  --spacing-page: 32rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-card-gap: 20rpx;
  --spacing-section: 40rpx;
  --font-size-xs: 12px;
  --font-size-sm: 13px;
  --font-size-base: 14px;
  --font-size-md: 16px;
  --font-size-lg: 18px;
  --font-size-xl: 22px;
  --font-size-2xl: 26px;
  --font-size-3xl: 30px;
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

  background: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  font-size: var(--font-size-base);
  line-height: 1.6;
}

.page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin: var(--spacing-section) var(--spacing-page) var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: var(--color-primary);
  flex-shrink: 0;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-outline {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.btn-outline:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-gold {
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 24rpx;
  text-align: center;
  font-size: var(--font-size-md);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.btn-gold:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

.empty-action {
  margin-top: 32rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-btn);
  padding: 20rpx 48rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
  transition: transform var(--duration-fast) var(--ease-out);
}

.empty-action:active {
  transform: scale(0.97);
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-tag);
  font-size: var(--font-size-xs);
  font-weight: 500;
}

.tag-warn {
  background: var(--color-warn-light);
  color: var(--color-warn);
}

.tag-green {
  background: var(--color-success-light);
  color: var(--color-success);
}

.tag-gold {
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.tag-red {
  background: var(--color-warn-light);
  color: var(--color-warn);
}

.risk-card {
  background: var(--color-warn-light);
  border: 1rpx solid #FECACA;
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.risk-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-warn);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.risk-text {
  font-size: var(--font-size-sm);
  color: #991B1B;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.suggest-card {
  background: var(--color-caution-light);
  border: 1rpx solid #FDE68A;
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.suggest-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-caution);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.suggest-list {
  padding-left: 32rpx;
}

.suggest-list-item {
  font-size: var(--font-size-sm);
  color: #78350F;
  line-height: 1.8;
}

.detail-section {
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.detail-section-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-key {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-val {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.detail-val.warn {
  color: var(--color-warn);
}

.detail-val.green {
  color: var(--color-success);
}

.detail-val.gold {
  color: var(--color-primary);
  font-weight: 600;
}

.ai-summary {
  background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.ai-summary-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-caution);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ai-summary-text {
  font-size: var(--font-size-sm);
  color: #78350F;
  line-height: 1.7;
}

.budget-card {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.budget-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-info);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.budget-range {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: var(--color-info);
  margin-bottom: 4rpx;
}

.budget-note {
  font-size: var(--font-size-xs);
  color: var(--color-info);
}

.validation-card {
  background: var(--color-caution-light);
  border: 1rpx solid #FDE68A;
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
}

.validation-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-caution);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.validation-text {
  font-size: var(--font-size-sm);
  color: #78350F;
  line-height: 1.6;
}

.validation-error-item {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  line-height: 1.4;
  margin-top: 4rpx;
}

.footer {
  padding: var(--spacing-md) var(--spacing-page);
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  margin-top: var(--spacing-md);
}

.footer-btn-row {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}

.footer-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: var(--radius-btn);
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.footer-btn:active {
  transform: scale(0.97);
}

.footer-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

.footer-btn.outline {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.footer-btn.gold {
  background: var(--color-primary);
  color: #fff;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cost-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.cost-val {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-primary);
}

.upgrade-card {
  background: linear-gradient(135deg, #1C1917, #292524);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg) var(--spacing-md);
  margin: var(--spacing-card-gap) var(--spacing-page);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upgrade-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: #F59E0B;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.upgrade-desc {
  font-size: var(--font-size-sm);
  color: #D1D5DB;
  margin-bottom: 20rpx;
}

.upgrade-btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 36rpx;
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 600;
  display: inline-block;
  transition: transform var(--duration-fast) var(--ease-out);
}

.upgrade-btn:active {
  transform: scale(0.97);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.anim-fade-in {
  animation: fadeIn var(--duration-normal) var(--ease-out) both;
}

.btn-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.btn-loading {
  position: relative;
  pointer-events: none;
  opacity: 0.75;
}

.btn-loading::after {
  content: '';
  display: inline-block;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  margin-left: 12rpx;
  vertical-align: middle;
}

.btn-loading.btn-outline::after,
.btn-loading.btn-outline-dark::after {
  border-color: rgba(0, 0, 0, 0.15);
  border-top-color: var(--text-secondary);
}

.input-wrap {
  position: relative;
}

.input-focus {
  border-color: var(--color-primary) !important;
  box-shadow: 0 0 0 4rpx rgba(184, 115, 0, 0.12);
}

.input-error {
  border-color: var(--color-warn) !important;
  box-shadow: 0 0 0 4rpx rgba(220, 38, 38, 0.1);
}

.input-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.input-clear::after {
  content: '✕';
  font-size: 10px;
  color: #fff;
}

.form-error-msg {
  font-size: var(--font-size-xs);
  color: var(--color-warn);
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.form-hint {
  font-size: var(--font-size-xs);
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.empty-search {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-search-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.empty-search-desc {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

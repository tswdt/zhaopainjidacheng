.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx var(--spacing-page) 28rpx;
  background: var(--bg-card);
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: linear-gradient(145deg, #F5E6CC, #FEF3C7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.avatar {
  font-size: 48px;
}

.user-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.credits-card {
  margin: var(--spacing-card-gap) var(--spacing-page);
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.credits-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.credits-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.credits-value {
  font-size: var(--font-size-3xl);
  font-weight: 800;
  color: var(--color-primary);
}

.credits-btn {
  background: linear-gradient(135deg, #C47A00, #B87300);
  color: #fff;
  border-radius: 28rpx;
  padding: 16rpx 36rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
}

.credits-btn:active {
  opacity: 0.85;
}

.stats-row {
  display: flex;
  padding: 0 var(--spacing-page);
  gap: var(--spacing-card-gap);
  margin-bottom: var(--spacing-card-gap);
}

.stat-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.upgrade-card {
  background: linear-gradient(145deg, #1C1917, #292524);
  border-radius: var(--radius-card);
  padding: 28rpx;
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upgrade-top {
  flex: 1;
}

.upgrade-btn {
  background: linear-gradient(135deg, #C47A00, #B87300);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: var(--font-size-sm);
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.upgrade-btn:active {
  opacity: 0.85;
}

.menu-list {
  padding: 0 var(--spacing-page);
  margin-top: 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
  transition: opacity 0.15s;
}

.menu-item:active {
  opacity: 0.85;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.menu-icon-text {
  font-size: 22px;
}

.menu-text {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 20px;
  color: var(--text-tertiary);
}

<view class="page">
  <view class="scan-header">
    <view class="scan-title">选择上传方式</view>
    <view class="scan-subtitle">拍照、上传图片或文档，AI自动识别</view>
  </view>

  <view class="scan-grid">
    <view class="scan-card" bindtap="takePhoto">
      <view class="scan-card-icon">📸</view>
      <view class="scan-card-name">拍照识别</view>
      <view class="scan-card-desc">实时拍照，即时分析</view>
    </view>
    <view class="scan-card" bindtap="chooseImage">
      <view class="scan-card-icon">🖼️</view>
      <view class="scan-card-name">上传图片</view>
      <view class="scan-card-desc">从相册选择图片</view>
    </view>
    <view class="scan-card" bindtap="chooseDocument">
      <view class="scan-card-icon">📄</view>
      <view class="scan-card-name">上传文档</view>
      <view class="scan-card-desc">PDF/Word等文档</view>
    </view>
    <view class="scan-card" bindtap="batchProcess">
      <view class="scan-card-icon">📁</view>
      <view class="scan-card-name">批量处理</view>
      <view class="scan-card-desc">多文件同时处理</view>
    </view>
  </view>

  <view class="section-title">快速场景</view>
  <view class="quick-grid">
    <view class="quick-card" wx:for="{{quickScenes}}" wx:key="sceneId" bindtap="selectScene" data-scene-id="{{item.sceneId}}">
      <view class="quick-icon" style="background:{{item.iconBg}}">{{item.icon}}</view>
      <view class="quick-name">{{item.name}}</view>
    </view>
  </view>
</view>

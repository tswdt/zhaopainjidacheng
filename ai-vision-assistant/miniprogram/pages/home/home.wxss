.page-home {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-page);
}

.header {
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-sm);
  background: var(--color-bg-card);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.greeting-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.search-bar {
  --td-search-bg-color: var(--color-bg-input);
  --td-search-height: 80rpx;
}

.content {
  flex: 1;
  overflow: hidden;
}

.banner-section {
  padding: var(--spacing-md) var(--spacing-lg);
}

.banner-swiper {
  border-radius: var(--radius-lg);
  overflow: hidden;
  height: 280rpx;
}

.capability-section {
  padding: 0 var(--spacing-lg);
}

.capability-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-md);
}

.capability-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: transform 0.15s ease;
}

.capability-item:active {
  transform: scale(0.95);
}

.capability-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.capability-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.hot-section {
  padding: 0 var(--spacing-lg);
}

.hot-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.hot-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  gap: var(--spacing-md);
}

.hot-item:active {
  opacity: 0.8;
}

.hot-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hot-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.hot-price {
  font-size: var(--font-size-xs);
  color: var(--color-accent);
  margin-top: 4rpx;
}

.recent-section {
  padding: 0 var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  gap: var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-sm);
}

.recent-item:active {
  opacity: 0.8;
}

.recent-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recent-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recent-title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.recent-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-placeholder);
}

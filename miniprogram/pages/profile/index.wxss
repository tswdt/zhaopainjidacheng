.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx var(--spacing-page) 28rpx;
  background: var(--bg-card);
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: linear-gradient(145deg, #F5E6CC, #FEF3C7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.credits-card {
  margin: var(--spacing-card-gap) var(--spacing-page);
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.credits-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.credits-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.credits-value {
  font-size: var(--font-size-3xl);
  font-weight: 800;
  color: var(--color-primary);
}

.credits-btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 28rpx;
  padding: 16rpx 36rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out);
}

.credits-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.stats-row {
  display: flex;
  padding: 0 var(--spacing-page);
  gap: var(--spacing-card-gap);
  margin-bottom: var(--spacing-card-gap);
}

.stat-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.upgrade-card {
  background: linear-gradient(145deg, #1C1917, #292524);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin: 0 var(--spacing-page) var(--spacing-card-gap);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upgrade-top {
  flex: 1;
}

.upgrade-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: #F59E0B;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.upgrade-desc {
  font-size: var(--font-size-sm);
  color: #D1D5DB;
  margin-bottom: 4rpx;
}

.upgrade-btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: var(--font-size-sm);
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 16rpx;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-fast) var(--ease-out);
}

.upgrade-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.menu-list {
  padding: 0 var(--spacing-page);
  margin-top: 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-card-gap);
  box-shadow: var(--shadow-card);
  min-height: 96rpx;
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast) var(--ease-out);
}

.menu-item:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--text-primary);
}
